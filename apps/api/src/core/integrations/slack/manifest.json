{
  "display_information": {
    "name": "Drift",
    "description": "Project channels information recap",
    "background_color": "#1a1a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "Drift",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://localhost:3000/slack/oauth/callback",
      "https://96f2-92-173-34-235.ngrok-free.app/slack/oauth/callback"
    ],
    "scopes": {
      "bot": [
        "channels:read",
        "channels:history",
        "groups:history",
        "groups:read",
        "users:read",
        "users:read.email",
        "chat:write"
      ],
      "user": ["groups:read", "groups:history", "channels:read", "channels:history"]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://localhost:3000/slack/events",
      "user_events": ["message.channels", "message.groups", "message.im", "message.mpim", "reaction_added"]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://localhost:3000/slack/events"
    },
    "socket_mode_enabled": false
  }
}
